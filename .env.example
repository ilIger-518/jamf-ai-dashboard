# ══════════════════════════════════════════════════════════════
#  Jamf AI Dashboard — Environment Variable Reference
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# Full async PostgreSQL connection URL.
# Docker Compose sets this automatically; override for external DBs.
DATABASE_URL=postgresql+asyncpg://jamfdash:changeme@localhost:5432/jamfdash

# PostgreSQL password (used by docker-compose.yml)
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret-key

JWT_ALGORITHM=HS256

# Set true only when app is served over HTTPS.
# Keep false for local http://localhost testing.
COOKIE_SECURE=false

# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet key for encrypting stored Jamf credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-a-fernet-key

# ── Jamf Pro Servers ──────────────────────────────────────────
# Add as many numbered server blocks as needed.
# All configured servers are synced automatically.

# Server 1
JAMF_SERVER_1_URL=https://your-jamf-server.jamfcloud.com
JAMF_SERVER_1_CLIENT_ID=your-client-id
JAMF_SERVER_1_CLIENT_SECRET=your-client-secret
JAMF_SERVER_1_NAME=Production

# Dedicated read-only credentials used exclusively by the AI module.
# These credentials must have Read-only API privileges in Jamf Pro.
JAMF_SERVER_1_AI_CLIENT_ID=your-readonly-ai-client-id
JAMF_SERVER_1_AI_CLIENT_SECRET=your-readonly-ai-client-secret

# Server 2 (optional)
# JAMF_SERVER_2_URL=https://your-second-server.jamfcloud.com
# JAMF_SERVER_2_CLIENT_ID=
# JAMF_SERVER_2_CLIENT_SECRET=
# JAMF_SERVER_2_NAME=Staging

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Ollama / LLM ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Chat model to use.  Pull it first: docker exec -it ollama ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b

# Embedding model.  Pull it first: docker exec -it ollama ollama pull nomic-embed-text
EMBEDDING_MODEL_NAME=nomic-embed-text

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.2

# Maximum tokens in the LLM context window
LLM_CONTEXT_WINDOW=4096

# ── Sync ──────────────────────────────────────────────────────
# How often (in minutes) to sync data from Jamf Pro servers
SYNC_INTERVAL_MINUTES=15

# ── CORS ──────────────────────────────────────────────────────
# JSON array OR comma-separated list of allowed frontend origins.
# JSON array (recommended): CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]
# Comma-separated (also supported): CORS_ORIGINS=http://localhost:3000,https://your-domain.com
CORS_ORIGINS=["http://localhost:3000"]

# ── Logging ───────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Frontend (Next.js public vars) ────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Microsoft SSO (Entra ID / Azure AD) ───────────────────────
# Enable OIDC sign-in via Microsoft identity platform
MICROSOFT_SSO_ENABLED=false

# Tenant ID (GUID) or "common" for multi-tenant
MICROSOFT_TENANT_ID=common

# App registration client credentials
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Backend callback URL registered in Microsoft app
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/microsoft/callback

# Frontend origin used for post-login redirect
FRONTEND_BASE_URL=http://localhost:3000

# ── Auto-updater ───────────────────────────────────────────────
# GitHub repo in "owner/repo" format — leave blank to use plain git fetch
GITHUB_REPO=

# Branch to track for updates
GITHUB_BRANCH=main

# Optional GitHub PAT to avoid rate-limiting on the API
GITHUB_TOKEN=

# How often to poll for updates (minutes)
UPDATE_CHECK_INTERVAL_MINUTES=60

# Set to true for fully automated, unattended updates
AUTO_UPDATE_ENABLED=false

# Seconds to wait for health check before triggering rollback
ROLLBACK_TIMEOUT_SECONDS=90
